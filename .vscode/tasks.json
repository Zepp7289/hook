{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean",
            "type": "shell",
            "command": "make clean",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Make",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Push",
            "type": "shell",
            "command": "adb push hook.kpm /sdcard/Download/kpm/",
            "dependsOn": [
                "Clean",
                "Make"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}